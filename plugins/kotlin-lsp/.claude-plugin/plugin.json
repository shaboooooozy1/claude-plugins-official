{
  "name": "kotlin-lsp",
  "description": "Kotlin language server for code intelligence",
  "version": "1.0.0",
  "author": {
    "name": "Anthropic",
    "email": "support@anthropic.com"
  },
  "lspServers": {
    "kotlin-lsp": {
      "command": "kotlin-lsp",
      "args": [
        "--stdio"
      ],
      "extensionToLanguage": {
        ".kt": "kotlin",
        ".kts": "kotlin"
      },
      "startupTimeout": 120000
    }
  }
}
