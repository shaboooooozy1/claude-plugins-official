{
  "name": "pyright-lsp",
  "description": "Python language server (Pyright) for type checking and code intelligence",
  "version": "1.0.0",
  "author": {
    "name": "Anthropic",
    "email": "support@anthropic.com"
  },
  "lspServers": {
    "pyright": {
      "command": "pyright-langserver",
      "args": [
        "--stdio"
      ],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  }
}
